# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL=postgresql://learnpool:localdev@localhost:5432/learnpool
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

OPENAI_API_KEY=sk-...

# OCI Object Storage (used by professor upload flow, not student chat)
OCI_NAMESPACE=
OCI_BUCKET=learnpool-documents

# CORS — comma-separated list of allowed frontend origins
# Dev default is http://localhost:5173 if unset
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting — max AI questions a student can ask per session
MAX_QUESTIONS_PER_SESSION=10
