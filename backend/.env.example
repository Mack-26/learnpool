# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL=postgresql://learnpool:localdev@localhost:5432/learnpool
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

OPENAI_API_KEY=sk-...

# Azure Blob Storage — leave empty to use local disk (dev mode)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents

# CORS — comma-separated list of allowed frontend origins
# Dev default is http://localhost:5173 if unset
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting — max AI questions a student can ask per session
MAX_QUESTIONS_PER_SESSION=10
